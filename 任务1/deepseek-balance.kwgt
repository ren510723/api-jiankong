{
  "version": 4,
  "config": {
    "api_url": "https://api.deepseek.com/user/balance",
    "api_key": "",
    "bearer_token": true,
    "refresh_interval": 120,
    "currency_symbol": "¥"
  },
  "widget": {
    "width": 2,
    "height": 1,
    "minWidthDp": 180,
    "minHeightDp": 90,
    "maxWidthDp": 360,
    "maxHeightDp": 120,
    "preview": true,
    "gridSpanX": 2,
    "gridSpanY": 1,
    "paddingLeft": 16,
    "paddingRight": 16,
    "paddingTop": 16,
    "paddingBottom": 16,
    "background": {
      "type": "linearGradient",
      "angle": 135,
      "colors": ["#1a1a2e", "#16213e", "#0f3460"],
      "centerX": 0.5,
      "centerY": 0.5,
      "radius": 0.5,
      "tileMode": "clamp"
    },
    "elements": [
      {
        "type": "Text",
        "x": 0,
        "y": 0,
        "width": 100,
        "height": 24,
        "text": "DeepSeek",
        "textSize": 12,
        "textColor": "#ffffff",
        "textAlpha": 0.7,
        "fontStyle": 0,
        "fontWeight": 500,
        "alignment": 0,
        "shadowColor": "#000000",
        "shadowRadius": 0,
        "shadowDx": 0,
        "shadowDy": 0
      },
      {
        "type": "Shape",
        "x": 0,
        "y": 32,
        "width": 8,
        "height": 8,
        "shapeType": 1,
        "color": "#4ade80",
        "cornerRadius": 4,
        "alpha": 1,
        "animate": {
          "type": "pulse",
          "duration": 2000,
          "repeat": -1
        }
      },
      {
        "type": "Text",
        "x": 12,
        "y": 28,
        "width": 80,
        "height": 20,
        "text": "$br(time, 'HH:mm')",
        "textSize": 11,
        "textColor": "#ffffff",
        "textAlpha": 0.5,
        "fontStyle": 0,
        "fontWeight": 400,
        "alignment": 0
      },
      {
        "type": "Text",
        "x": 0,
        "y": 52,
        "width": 100,
        "height": 40,
        "text": "$httpGET(api_url, {headers: {Authorization: 'Bearer ' + api_key}})",
        "textSize": 28,
        "textColor": "#ffffff",
        "textAlpha": 1,
        "fontStyle": 0,
        "fontWeight": 700,
        "alignment": 0,
        "shadowColor": "#667eea",
        "shadowRadius": 8,
        "shadowDx": 0,
        "shadowDy": 0,
        "variable": "raw_data",
        "refreshInterval": 120
      },
      {
        "type": "Text",
        "x": 0,
        "y": 52,
        "width": 100,
        "height": 40,
        "text": "$if(raw_data, currency_symbol + ' ' + js('JSON.parse(raw_data).balance_infos[0].total_balance'), '--')",
        "textSize": 32,
        "textColor": "#ffffff",
        "textAlpha": 1,
        "fontStyle": 0,
        "fontWeight": 700,
        "alignment": 0,
        "shadowColor": "#667eea",
        "shadowRadius": 10,
        "shadowDx": 0,
        "shadowDy": 0,
        "refreshInterval": 120
      },
      {
        "type": "Text",
        "x": 0,
        "y": 88,
        "width": 100,
        "height": 16,
        "text": "余额",
        "textSize": 10,
        "textColor": "#ffffff",
        "textAlpha": 0.4,
        "fontStyle": 0,
        "fontWeight": 400,
        "alignment": 0
      }
    ]
  },
  "package": "org.kustom.widget",
  "name": "DeepSeek Balance",
  "description": "DeepSeek API 余额监控小组件",
  "author": "Custom Widget",
  "category": "finance",
  "tags": ["deepseek", "api", "balance", "finance"],
  "versionCode": 1,
  "versionName": "1.0.0"
}
