<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="DeepSeek 余额"
        android:supportsRtl="true"
        android:theme="@style/Theme.DeepSeekBalance"
        android:usesCleartextTraffic="false">

        <!-- 配置 Activity -->
        <activity
            android:name=".config.ConfigActivity"
            android:exported="true"
            android:label="DeepSeek 余额配置">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 桌面小组件 -->
        <receiver
            android:name=".widget.BalanceWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.deepseek.balance.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/balance_widget_info" />
        </receiver>

        <!-- 定时刷新 -->
        <receiver
            android:name=".widget.WidgetUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.deepseek.balance.ACTION_UPDATE" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
