<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DeepSeek 余额"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="配置 API 后即可在桌面小组件中查看余额"
            android:textColor="@color/widget_text_tertiary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- API 地址 -->
        <TextView
            style="@style/LabelStyle"
            android:text="API 地址" />
        <EditText
            android:id="@+id/etApiUrl"
            style="@style/InputStyle"
            android:hint="https://api.deepseek.com/user/balance"
            android:inputType="textUri" />

        <!-- API Key -->
        <TextView
            style="@style/LabelStyle"
            android:text="API Key" />
        <EditText
            android:id="@+id/etApiKey"
            style="@style/InputStyle"
            android:hint="sk-xxxxxxxxxxxx"
            android:inputType="textPassword" />

        <!-- 货币单位 -->
        <TextView
            style="@style/LabelStyle"
            android:text="货币单位" />
        <EditText
            android:id="@+id/etCurrency"
            style="@style/InputStyle"
            android:hint="¥"
            android:inputType="text"
            android:maxLength="5" />

        <!-- 刷新间隔 -->
        <TextView
            style="@style/LabelStyle"
            android:text="自动刷新间隔（分钟）" />
        <EditText
            android:id="@+id/etRefreshInterval"
            style="@style/InputStyle"
            android:hint="30"
            android:inputType="number" />

        <!-- 测试结果 -->
        <TextView
            android:id="@+id/tvTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- 按钮 -->
        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_secondary"
            android:text="测试连接"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_primary"
            android:text="保存并刷新"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="提示：保存配置后，长按桌面空白处添加小组件即可在桌面查看余额。"
            android:textColor="@color/widget_text_tertiary"
            android:textSize="12sp"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>
</ScrollView>
